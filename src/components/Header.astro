---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
    <nav>
        <div class="logo">
            <h2><a href="/">{SITE_TITLE}</a></h2>
        </div>
        <div class="internal-links">
            <HeaderLink href="/">Home</HeaderLink>
            <HeaderLink href="/blog">Blog</HeaderLink>
            <HeaderLink href="/portfolio">Portfolio</HeaderLink>
        </div>
    </nav>
</header>

<style>
    header {
        margin: 0;
        padding: 0;
        /* Glassmorphism effect */
        background: rgba(var(--bg-base), 0.7);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        
        position: sticky;
        top: 0;
        z-index: 100;
        border-bottom: 1px solid rgb(var(--border-soft));
    }

    nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        max-width: 720px; /* Matching your main container width */
        margin: 0 auto;
        padding: 0 1em;
    }

    .logo h2 {
        margin: 0;
        font-size: 1.2em;
        font-weight: 700;
        letter-spacing: -0.02em;
    }

    .logo a {
        color: rgb(var(--text-pure));
        text-decoration: none;
        transition: var(--transition);
    }

    .logo a:hover {
        color: var(--accent);
    }

    .internal-links {
        display: flex;
        gap: 0.5rem;
    }

    /* HeaderLink styling */
    nav :global(a) {
        padding: 1.5em 0.75em;
        color: rgb(var(--text-secondary));
        border-bottom: 2px solid transparent;
        text-decoration: none;
        font-weight: 500;
        font-size: 0.95rem;
        transition: var(--transition);
    }

    nav :global(a:hover) {
        color: var(--accent);
    }

    /* Active state for HeaderLink */
    nav :global(a.active) {
        color: var(--accent);
        border-bottom-color: var(--accent);
    }

    @media (max-width: 720px) {
        nav {
            padding: 0 1.25em;
        }
        
        .logo h2 {
            font-size: 1em;
        }

        nav :global(a) {
            padding: 1.2em 0.5em;
            font-size: 0.9rem;
        }
    }
</style>
