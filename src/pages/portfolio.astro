---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { projects } from '../content/projects';
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead title={`Portfolio – ${SITE_TITLE}`} description="Projects by Stef" />
    </head>
    <body>
        <Header />

        <main>
            <section class="hero">
                <span class="eyebrow">Work & Experiments</span>
                <h1>My Projects</h1>
                <p class="hero-text">A selection of tools, platforms, and designs I’ve built. Click a card to explore the live version.</p>
            </section>

            <section class="home-grid portfolio-grid">
                {projects.map(project => (
                    <a href={project.url || '#'} target="_blank" rel="noopener noreferrer" class="card">
                        {project.image && (
                            <div class="image-container">
                                <img src={project.image} alt={project.name} loading="lazy" />
                            </div>
                        )}
                        <div class="card-content">
                            {/* Optional: Add category/tag if available in your project data */}
                            {project.category && <span class="eyebrow">{project.category}</span>}
                            <h2>{project.name}</h2>
                            <p>{project.description}</p>
                            
                            <div class="card-footer">
                                <span class="link-text">View Project ↗</span>
                            </div>
                        </div>
                    </a>
                ))}
            </section>
        </main>

        <Footer />
    </body>
</html>

<style>
    /* Specific tweaks to make the portfolio grid extra "nice" */
    .hero {
        margin-bottom: 4rem;
        text-align: center;
    }

    .hero-text {
        font-size: 1.25rem;
        max-width: 600px;
        margin: 1rem auto 0;
        opacity: 0.8;
    }

    .card {
        display: flex;
        flex-direction: column;
        height: 100%;
        text-decoration: none; /* Reset link style */
    }

    .card-content {
        display: flex;
        flex-direction: column;
        flex-grow: 1;
        padding-top: 0.5rem;
    }

    .card h2 {
        margin: 0.5rem 0;
        font-size: 1.5rem;
        transition: color 0.2s ease;
    }

    .card:hover h2 {
        color: var(--accent);
    }

    .card p {
        font-size: 1rem;
        line-height: 1.5;
        margin-bottom: 1.5rem;
        color: var(--text-muted);
    }

    .card-footer {
        margin-top: auto;
        font-size: 0.9rem;
        font-weight: 700;
        color: var(--accent);
    }

    /* Keep the image crisp inside the glass card */
    .image-container {
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 1.25rem;
    }
    
    .image-container img {
        margin: 0;
        transition: transform 0.5s ease;
    }

    .card:hover img {
        transform: scale(1.05);
    }
</style>
