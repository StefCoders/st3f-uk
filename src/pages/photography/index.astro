---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('photography')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const getImagePath = (heroImage: string) => {
    const parts = heroImage.split('/photography/');
    const relativePath = parts.length > 1 ? parts[1] : '';
    if (!relativePath) return '';
    const cleanPath = relativePath.replace(/\.[^.]+$/, '');
    return `/_generated/photography/${cleanPath}`;
};
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead title={`Photography • ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
        <style>
            :root {
                --glass-bg: rgba(255, 255, 255, 0.03);
                --glass-border: rgba(255, 255, 255, 0.1);
                --glass-blur: 15px;
            }

            .photo-list {
                display: flex;
                flex-direction: column;
                gap: 3rem;
                list-style: none;
                padding: 2rem 1rem;
                max-width: 1100px;
                margin: 0 auto;
            }

            .post-card a {
                display: flex;
                flex-direction: row;
                gap: 3rem;
                text-decoration: none;
                color: inherit;
                align-items: center;
                padding: 2rem;
                
                background: var(--glass-bg);
                backdrop-filter: blur(var(--glass-blur));
                -webkit-backdrop-filter: blur(var(--glass-blur));
                border: 1px solid var(--glass-border);
                border-radius: 32px;
                transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
            }

            .post-card a:hover {
                background: rgba(255, 255, 255, 0.08);
                border-color: rgba(255, 255, 255, 0.3);
                transform: translateX(10px);
            }

            .img-wrapper img {
                display: block;
                width: auto;
                height: auto;
                max-width: 100%;
                max-height: 280px;
                object-fit: contain;
                transition: transform 0.6s ease;
            }

            .post-card a:hover .img-wrapper img {
                transform: scale(1.04);
            }

            .content {
                flex: 2; /* Gives text significantly more priority */
                display: flex;
                flex-direction: column;
                justify-content: center;
            }

            .date-tag {
                font-size: 0.75rem;
                text-transform: uppercase;
                letter-spacing: 0.15rem;
                opacity: 0.4;
                margin-bottom: 0.75rem;
            }

            h2 {
                margin: 0 0 1rem 0;
                font-size: 2.2rem;
                font-weight: 800;
                line-height: 1.1;
                letter-spacing: -0.02em;
                color: #fff;
            }

            p {
                margin: 0;
                opacity: 0.6;
                font-size: 1.1rem;
                line-height: 1.7;
                max-width: 500px; /* Prevents text from becoming too long to read */
            }

            @media (max-width: 850px) {
                .post-card a {
                    flex-direction: column;
                    align-items: flex-start;
                    gap: 2rem;
                    padding: 1.5rem;
                }
                .img-wrapper {
                    max-width: 100%;
                    width: 100%;
                    justify-content: center;
                }
                h2 { font-size: 1.8rem; }
            }
        </style>
    </head>
    <body>
        <Header />
        <main>
            <section>
                <ul class="photo-list">
                    {posts.map((post) => {
                        const base = post.data.heroImage ? getImagePath(post.data.heroImage) : null;
                        return (
                            <li class="post-card">
                                <a href={`/photography/${post.id}/`}>
                                    <div class="img-wrapper">
                                        {base && (
                                            <img 
                                                src={`${base}-w800.jpg`} 
                                                srcset={`${base}-w480.jpg 480w, ${base}-w800.jpg 800w`} 
                                                sizes="(max-width: 850px) 100vw, 400px"
                                                alt={post.data.title} 
                                                loading="lazy" 
                                            />
                                        )}
                                    </div>
                                    <div class="content">
                                        <span class="date-tag">
                                            <FormattedDate date={post.data.pubDate} />
                                        </span>
                                        <h2>{post.data.title}</h2>
                                        {post.data.description && <p>{post.data.description}</p>}
                                    </div>
                                </a>
                            </li>
                        );
                    })}
                </ul>
            </section>
        </main>
        <Footer />
    </body>
</html>