---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
        <style>
            /* 1. Grid Layout */
            .blog-list {
                display: grid;
                grid-template-columns: repeat(2, 1fr);
                gap: 2rem;
                list-style-type: none;
                margin: 0;
                padding: 0;
            }

            /* 2. Featured Post Styling */
            .blog-list li:first-child {
                grid-column: 1 / -1;
                margin-bottom: 2rem;
            }

            .blog-list li:first-child .card {
                display: flex;
                flex-direction: column;
                padding: 2rem;
                background: rgba(0, 163, 255, 0.05); /* Slight blue tint for featured */
                border-color: rgba(0, 163, 255, 0.2);
            }

            @media (min-width: 720px) {
                .blog-list li:first-child .card {
                    flex-direction: row;
                    align-items: center;
                    gap: 3rem;
                }
                .blog-list li:first-child .featured-img-wrapper {
                    width: 60%;
                }
                .blog-list li:first-child .content {
                    width: 40%;
                }
            }

            /* 3. Image Handling */
            .img-wrapper {
                overflow: hidden;
                border-radius: 12px;
                line-height: 0;
            }

            img {
                width: 100%;
                height: auto;
                transition: transform 0.5s ease;
                object-fit: cover;
                aspect-ratio: 16 / 9;
            }

            .post-link:hover img {
                transform: scale(1.03);
            }

            /* 4. Content Styling */
            .post-link {
                text-decoration: none;
                color: inherit;
            }

            .content {
                padding-top: 1.5rem;
            }

            .title {
                margin: 0.5rem 0;
                font-size: 1.5rem;
                color: var(--text-bright);
                transition: color 0.2s ease;
            }

            .post-link:hover .title {
                color: var(--accent);
            }

            .date {
                font-size: 0.85rem;
                text-transform: uppercase;
                letter-spacing: 0.1em;
                color: var(--accent); /* Blue highlight for dates */
            }

            /* 5. Mobile Adjustments */
            @media (max-width: 720px) {
                .blog-list {
                    grid-template-columns: 1fr;
                    gap: 1.5rem;
                }
                .title {
                    font-size: 1.25rem;
                }
            }
        </style>
    </head>
    <body>
        <Header />
        <main>
            <section class="hero">
                <span class="eyebrow">Journal</span>
                <h1>Writing & Ideas</h1>
            </section>

            <section>
                <ul class="blog-list">
                    {
                        posts.map((post) => (
                            <li>
                                <a href={`/blog/${post.id}/`} class="post-link">
                                    <article class="card">
                                        <div class="img-wrapper featured-img-wrapper">
                                            <img 
                                                width={720} 
                                                height={360} 
                                                src={post.data.heroImage} 
                                                alt="" 
                                                loading="lazy"
                                            />
                                        </div>
                                        <div class="content">
                                            <span class="date">
                                                <FormattedDate date={post.data.pubDate} />
                                            </span>
                                            <h4 class="title">{post.data.title}</h4>
                                            {/* Show description only on featured post */}
                                            <p class="description" style="display: none;">{post.data.description}</p>
                                        </div>
                                    </article>
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </section>
        </main>
        <Footer />
    </body>
</html>
