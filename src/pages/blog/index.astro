---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
        <style>
            /* Simple, Minimalist Vertical List */
            .blog-list {
                list-style-type: none;
                margin: 0;
                padding: 0;
                display: flex;
                flex-direction: column;
                gap: 1.5rem; /* Space between posts */
            }

            .post-item {
                display: block;
                text-decoration: none;
                color: inherit;
            }

            /* The 'Card' is now just a subtle text container */
            .card {
                padding: 1.5rem;
                display: flex;
                flex-direction: column;
                transition: transform 0.2s ease;
            }

            .post-item:hover .card {
                transform: translateX(4px); /* Subtle shift rather than scaling */
                border-color: var(--accent);
            }

            /* Image is now treated as a simple inline element */
            img {
                width: 100%;
                height: auto; /* Natural scale */
                display: block;
                border-radius: 8px; /* Slightly tighter border */
                margin-bottom: 1rem;
                border: 1px solid var(--glass-border);
            }

            /* Content Styling */
            .title {
                margin: 0.25rem 0 0.5rem 0;
                font-size: 1.75rem; /* Larger, readable titles */
                color: var(--text-bright);
                line-height: 1.2;
                letter-spacing: -0.01em;
                transition: color 0.2s ease;
            }

            .post-item:hover .title {
                color: var(--accent);
            }

            .date {
                font-size: 0.9rem;
                font-weight: 700;
                color: var(--accent); /* Electric Blue highlight */
            }

            .description {
                margin: 0;
                color: var(--text-muted);
                line-height: 1.6;
                font-size: 1rem;
            }

            /* Clean break for featured (optional, keeps it simple) */
            .blog-list li:first-child .card {
                background: rgba(0, 163, 255, 0.03); /* Barely-there blue tint */
            }

            @media (max-width: 720px) {
                .title { font-size: 1.4rem; }
                .card { padding: 1.25rem; }
            }
        </style>
    </head>
    <body>
        <Header />
        <main>
            <section class="hero">
                <span class="eyebrow">Journal</span>
                <h1>Writing & Ideas</h1>
            </section>

            <section>
                <ul class="blog-list">
                    {
                        posts.map((post) => (
                            <li>
                                <a href={`/blog/${post.id}/`} class="post-link post-item">
                                    <article class="card">
                                        {/* Image is now a simple, raw element */}
                                        {post.data.heroImage && (
                                            <img 
                                                src={post.data.heroImage} 
                                                alt="" 
                                                loading="lazy" 
                                            />
                                        )}
                                        
                                        <div class="content">
                                            <span class="date">
                                                <FormattedDate date={post.data.pubDate} />
                                            </span>
                                            <h2 class="title">{post.data.title}</h2>
                                            <p class="description">{post.data.description}</p>
                                        </div>
                                    </article>
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </section>
        </main>
        <Footer />
    </body>
</html>
