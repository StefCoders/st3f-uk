---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---
<!doctype html>
<html lang="en">
   <head>
      <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
      <style>
         .cta-container {
         display: grid;
         grid-template-columns: 1fr 1fr 1fr;
         gap: 1.5rem;
         margin-top: 2rem;
         }
         .cta-button {
         display: flex;
         flex-direction: column;
         align-items: center;
         justify-content: center;
         padding: 2rem;
         background: var(--glass-bg);
         border: 1px solid var(--glass-border);
         border-radius: 20px;
         backdrop-filter: blur(15px);
         text-decoration: none;
         transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
         text-align: center;
         }
         .cta-button strong {
         color: var(--text-bright);
         font-size: 1.2rem;
         margin-top: 0.5rem;
         }
         .cta-button:hover {
         border-color: var(--accent);
         background: rgba(0, 163, 255, 0.1);
         transform: translateY(-5px);
         box-shadow: 0 10px 30px -10px var(--accent-glow);
         }
         @media (max-width: 600px) {
         .cta-container { grid-template-columns: 1fr; }
         }
      </style>
   </head>
   <body>
      <Header />
      <main>
         <section class="hero-intro">
            <header>
               <p class="eyebrow">st3f.uk</p>
               <h1>Stef - developer, broadcaster and photograher</h1>
            </header>
            <div class="bio">
               <p>
                  I’m Stef, a UK-based developer, broadcaster and photographer originally from Romania. I build websites, streaming systems, radio infrastructure and side projects that turn ideas into something real.
               </p>
            </div>
         </section>
         <hr />
         <section class="expertise" aria-labelledby="expertise-title">
            <h2 id="expertise-title">About me.</h2>
            <div class="home-grid">
               <article class="card">
                  <h3>Radio</h3>
                  <p>I run, build and maintain multiple radio stations and their automation, streaming, and broadcast tools.</p>
               </article>
               <article class="card">
                  <h3>Code</h3>
                  <p>I build responsive websites, dashboards, and backend systems tailored to projects I manage.</p>
               </article>
               <article class="card">
                  <h3>Projects</h3>
                  <p>This site is where I’ll post updates, ideas and things I’m working on.</p>
               </article>
            </div>
         </section>
         <hr />
         <section class="network" aria-labelledby="network-title">
            <div class="cta-container">
               <a href="/blog" class="cta-button glass">
               <span class="eyebrow">Blog</span>
               <strong>Explore my blog</strong>
               </a>
               <a href="/portfolio" class="cta-button glass">
               <span class="eyebrow">Portfolio</span>
               <strong>See my work</strong>
               </a>
               <a href="/photography" class="cta-button glass">
               <span class="eyebrow">Gallery</span>
               <strong>View my photography</strong>
               </a>
            </div>
         </section>
      </main>
      <Footer />
   </body>
</html>
