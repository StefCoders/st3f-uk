---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<p class="eyebrow">st3f.uk</p>
				<h1>Stef - developer and radio enthusiast</h1>
			</section>

			<section class="home-grid">
				<div class="card">
					<h2>Radio</h2>
					<p>
						I run, build and maintain online radio, automation, streaming, and broadcast tools.
					</p>
				</div>

				<div class="card">
					<h2>Code</h2>
					<p>
						I create frontend & backend websites, apps and dashboards for the stuff I run.
					</p>
				</div>

				<div class="card">
					<h2>Projects</h2>
					<p>
						This site is where I’ll post updates, ideas, random tests, and things I’m working on.
					</p>
				</div>
			</section>

			<section class="home-section">
				<h2>About</h2>
				<p>
					I’m Stef, based in the UK, originally from Romania. I’m into radio, web development,
					streaming infrastructure, and building things from nothing.
				</p>
			</section>

			<section class="home-section">
				<h2>Stuff I run</h2>
				<ul>
					<li><a href="https://moinestifm.ro" target="_blank" rel="noopener noreferrer">Moinesti FM</a></li>
					<li><a href="https://lrradio.uk" target="_blank" rel="noopener noreferrer">London Romanian Radio</a></li>
					<li><a href="/blog">Blog</a></li>
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
